{
  "expo": {
   "name": "Vitalynx",
"slug": "HealthApp",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/branding/icons/vitalynx-app-icon-1024.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/branding/icons/vitalynx-app-icon-1024.png"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/marks/vitalynx-mark-400x400.png",
        "backgroundColor": "#F9C46E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.accusaga.vitalynx"
    },
    "web": {
      "favicon": "./assets/branding/icons/vitalynx-app-icon-192.png"
    },
    "extra": {
      "eas": {
        "projectId": "a30dac87-7d2d-4391-8162-90232a1815ea"
      }
    },
    "plugins": [
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "med-record",
          "organization": "medrecord-r1"
        }
      ],
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/vertical/vitalynx-logo-vertical-400.png",
          "backgroundColor": "#F9C46E",
          "imageWidth": 240
        }
      ]
    ]
  }
}